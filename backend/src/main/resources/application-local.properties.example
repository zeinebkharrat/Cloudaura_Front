# 1. Copy this file to: application-local.properties (same folder)
# 2. application-local.properties is gitignored — put real secrets only there.
# 3. Run the backend with: --spring.profiles.active=local
#
# Spring Boot loads application-local.properties when profile "local" is active.
# You can also set the same keys via environment variables (see application.properties).

# Optional: sign-in without email verification link (dev only)
# app.auth.require-email-verified-for-signin=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
IMGBB_API_KEY=
MAIL_USERNAME=
MAIL_APP_PASSWORD=
STRIPE_SECRET_KEY=
RECAPTCHA_SECRET=
RECAPTCHA_SITE_KEY=
