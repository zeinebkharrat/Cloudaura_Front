# 1. Copy this file to: application-local.properties (same folder)
# 2. application-local.properties is gitignored — put real secrets only there.
# 3. Run the backend with: --spring.profiles.active=local (recommended for full local overrides)
#
# Base defaults live in application.properties (tracked in git). Profile "local" loads this file
# on top of those defaults. You can also override any key via environment variables.

# Optional: sign-in without email verification link (dev only)
# app.auth.require-email-verified-for-signin=false

# Optional: local DB overrides (MySQL)
# spring.datasource.url=jdbc:mysql://localhost:3306/Yallatn?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# spring.datasource.username=root
# spring.datasource.password=
# spring.jpa.hibernate.ddl-auto=none

